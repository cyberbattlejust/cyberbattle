# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --------------------------------------------------

# Dependencies

# --------------------------------------------------

node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --------------------------------------------------

# Testing

# --------------------------------------------------

coverage/
test/

# --------------------------------------------------

# Next.js

# --------------------------------------------------

.next/
out/

# --------------------------------------------------

# Production / Build Output

# --------------------------------------------------

build/
dist/

# --------------------------------------------------

# Environment Files

# Do not commit real environment files.

# Commit .env.example instead.

# --------------------------------------------------

.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# Allow example environment file to be committed

!.env.example

# --------------------------------------------------

# Local Database Files

# SQLite database files may contain users, rooms, logs,

# hashed passwords, tokens, and testing data.

# --------------------------------------------------

db/*.db
db/*.sqlite
db/*.sqlite3
*.db
*.sqlite
*.sqlite3

# Keep db folder if needed, but ignore real database files

!db/.gitkeep

# --------------------------------------------------

# Logs

# --------------------------------------------------

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log

# --------------------------------------------------

# TypeScript / Cache

# --------------------------------------------------

*.tsbuildinfo
tsconfig.tsbuildinfo

# --------------------------------------------------

# IDE / Editor Files

# --------------------------------------------------

.vs/
.vscode/
.idea/

# --------------------------------------------------

# OS Files

# --------------------------------------------------

.DS_Store
Thumbs.db

# --------------------------------------------------

# Security / Certificates

# --------------------------------------------------

*.pem
*.key
*.crt

# --------------------------------------------------

# Vercel

# --------------------------------------------------

.vercel/

# --------------------------------------------------

# Local / Generated / Temporary Folders

# --------------------------------------------------

download/
.zscripts/
local-*
.claude/
.z-ai-config/
prompt/
skills/

# --------------------------------------------------

# Archives / Submission Packages

# Avoid committing compressed copies of the project.

# --------------------------------------------------

*.zip
*.7z
*.rar
*.tar
*.tar.gz

# --------------------------------------------------

# Optional: Bun binary lock file

# Keep bun.lock if it exists and is text-based.

# Ignore bun.lockb if generated.

# --------------------------------------------------

bun.lockb
