generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      String    @default("player")
  team      String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  gameLogs  GameLog[]
}

model GameState {
  id             String   @id @default(cuid())
  phase          String   @default("DEFENSE")
  vulnerabilities Int     @default(3)
  teams          Team[]
}

model Team {
  id             String    @id @default(cuid())
  name           String    @unique
  ssid           String
  displayName    String    @default("")
  password       String
  attackScore    Int       @default(0)
  defenseScore   Int       @default(0)
  gameState      GameState @relation(fields: [gameStateId], references: [id])
  gameStateId    String
}

model GameLog {
  id        String   @id @default(cuid())
  type      String
  team      String
  username  String
  action    String
  detail    String
  success   Boolean  @default(false)
  points    Int      @default(0)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Mission {
  id             String   @id @default(cuid())
  title          String
  description    String
  type           String
  difficulty     String   @default("medium")
  points         Int      @default(5)
  durationSec    Int      @default(120)
  answer         String   @default("")
  active         Boolean  @default(false)
  completedBy    String   @default("none")
  activatedBy    String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GameSession {
  id          String   @id @default(cuid())
  name        String
  creator     String   @default("")
  status      String   @default("waiting")
  maxTime     Int      @default(600)
  teamAScore  Int      @default(0)
  teamBScore  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GameRoom {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  supervisorEmail String        @default("")
  status          String        @default("waiting")
  winScore        Int           @default(100)
  maxPlayersPerTeam Int         @default(2)
  maxTime         Int           @default(600)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  teams           RoomTeam[]
  missions        RoomMission[]
  logs            RoomLog[]
}

model RoomTeam {
  id           String   @id @default(cuid())
  room         GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId       String
  slot         String
  ssid         String
  displayName  String   @default("")
  password     String
  attackScore  Int      @default(0)
  defenseScore Int      @default(0)
  configured   Boolean  @default(false)
  configuredBy String   @default("")
  leaderUsername String  @default("")
  updatedAt    DateTime @updatedAt

  @@unique([roomId, slot])
}

model RoomMission {
  id              String   @id @default(cuid())
  room            GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId          String
  sourceMissionId String   @default("")
  title           String
  description     String
  type            String
  difficulty      String   @default("medium")
  points          Int      @default(5)
  durationSec     Int      @default(120)
  answer          String   @default("")
  active          Boolean  @default(false)
  completedBy     String   @default("none")
  activatedBy     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([roomId, title])
}

model RoomLog {
  id        String   @id @default(cuid())
  room      GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  type      String
  team      String
  username  String
  action    String
  detail    String
  success   Boolean  @default(false)
  points    Int      @default(0)
  createdAt DateTime @default(now())
}
